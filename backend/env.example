# Server Configuration
NODE_ENV=development
PORT=3001

# PostgreSQL Database
DB_HOST=postgres
DB_PORT=5432
DB_NAME=factory_db
DB_USER=root_user
DB_PASSWORD=root_password

# JWT Secret (change this in production)
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=24h

# CORS
CORS_ORIGIN=http://localhost:5173

